---
import Layout from '../layouts/Layout.astro';
import { alumni } from '../data/alum';
import { Image } from 'astro:assets';
---

<Layout
  title="Alumni & Past Exec - DAISI"
  description="Meet the past executive members and alumni of the Durham AI Safety Initiative (DAISI)."
>
  <!-- Header -->
  <section class="section section-neutral">
    <div class="site-container text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Alumni &amp; Past Exec</h1>
      <div class="w-24 h-1 bg-gradient-to-r from-bright-purple to-light-purple mx-auto rounded-full mb-6"></div>
      <p class="text-lg max-w-2xl mx-auto leading-relaxed">
        Thanks to the people who helped build DAISI into what it is today!
      </p>
    </div>
  </section>

  <!-- Alumni Grid -->
  {alumni.length > 0 ? (
    <section class="section section-light">
      <div class="site-container">
        <div class="flex flex-wrap justify-center gap-8 max-w-6xl mx-auto">
          {alumni.map((person) => (
            <div class="text-center animate-on-scroll w-40 md:w-48">
              <div class="photo-wrap w-32 h-32 md:w-40 md:h-40 rounded-full mx-auto mb-4 flex items-center justify-center overflow-hidden bg-gradient-to-br from-bright-purple to-light-purple">
                {person.photo ? (
                  typeof person.photo === 'string' ? (
                    <img
                      src={person.photo}
                      alt={person.name}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover"
                      onerror="const fb=this.closest('.photo-wrap')?.querySelector('.fallback-icon'); if(fb){fb.style.display='flex'}; this.remove();"
                      style="width:100%; height:100%; object-fit: cover;"
                    />
                  ) : (
                    <Image
                      src={person.photo}
                      alt={person.name}
                      widths={[128,160,200,320]}
                      sizes="(min-width: 1024px) 160px, (min-width: 768px) 160px, 128px"
                      fit="cover"
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover"
                      onerror="const fb=this.closest('.photo-wrap')?.querySelector('.fallback-icon'); if(fb){fb.style.display='flex'}; this.remove();"
                    />
                  )
                ) : (
                  <i class="fas fa-user text-3xl text-white"></i>
                )}
                <div class="fallback-icon hidden" style="display:none; align-items:center; justify-content:center; width:100%; height:100%;">
                  <i class="fas fa-user text-3xl text-white"></i>
                </div>
              </div>
              {person.link ? (
                <h4 class="text-xl font-bold mb-2">
                  <a href={person.link} target="_blank" rel="noopener" class="text-bright-purple hover:text-light-purple transition-colors inline-flex items-center justify-center">
                    {person.name}
                    <i class="fas fa-external-link-alt ml-2 text-xs" aria-hidden="true"></i>
                  </a>
                </h4>
              ) : (
                <h4 class="text-xl font-bold mb-2">{person.name}</h4>
              )}
              <p class="font-semibold mb-2 text-sm text-violet-600">{person.role}</p>
              {person.years_active && (
                <p class="text-xs text-gray-500">{person.years_active}</p>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  ) : (
    <section class="section section-light">
      <div class="site-container text-center">
        <p class="text-lg text-slate-500">No alumni listed yet.</p>
      </div>
    </section>
  )}

  <!-- Back link -->
  <section class="section section-neutral">
    <div class="site-container text-center">
      <a href="/about/" class="inline-flex items-center text-bright-purple hover:text-light-purple font-semibold transition-colors">
        <i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>
        Back to About Us
      </a>
    </div>
  </section>
</Layout>
